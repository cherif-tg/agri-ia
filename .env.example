# Variables d'environnement - Prévision Agricole IA
# Copier ce fichier en .env et remplir les valeurs

# === STREAMLIT ===
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_ENABLE_CORS=false
STREAMLIT_SERVER_MAX_UPLOAD_SIZE=200
STREAMLIT_LOGGER_LEVEL=info

# === APPLICATION ===
APP_ENV=development  # development ou production
DEBUG=false

# === BASE DE DONNÉES ===
DATABASE_URL=sqlite:///data/predictions.db

# === MÉTÉO API ===
WEATHER_API_TIMEOUT=10
WEATHER_CACHE_TTL=600

# === SÉCURITÉ ===
# Pour authentification (optionnel)
# ADMIN_PASSWORD=your_secure_password
# SECRET_KEY=your_secret_key

# === SMTP (pour notifications email, optionnel) ===
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_EMAIL=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FILE=data/app.log

# === MONITORING (optionnel) ===
# SENTRY_DSN=https://your-sentry-key@sentry.io/project-id

# === HEROKU SPECIFIC ===
# FORCE_HTTPS=true
# SECRET_KEY_HEROKU=your_heroku_secret

# === DOCKER ===
DOCKER_PORT=8501
DOCKER_RESTART_POLICY=unless-stopped
